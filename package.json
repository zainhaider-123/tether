{
  "name": "tether",
  "version": "1.0.0",
  "description": "A language-agnostic CLI/TUI tool that manages skills like a package manager.",
  "type": "module",
  "bin": {
    "tether": "bin/tether.js"
  },
  "main": "dist/index.js",
  "scripts": {
